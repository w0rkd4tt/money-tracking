# =============================================================================
# Money Tracking — environment configuration
# Copy to .env and fill in. NEVER commit .env.
# =============================================================================

# ---------------------------------------------------------------------------
# App
# ---------------------------------------------------------------------------
APP_ENV=development
APP_BIND=127.0.0.1
APP_PORT_API=8000
APP_PORT_WEB=3000
TZ=Asia/Ho_Chi_Minh
DEFAULT_CURRENCY=VND
LOCALE=vi-VN

# ---------------------------------------------------------------------------
# Security (REQUIRED — generate with: openssl rand -base64 32)
# ---------------------------------------------------------------------------
APP_ENCRYPTION_KEY=
SESSION_SECRET=
# Optional, only needed if binding to 0.0.0.0 / LAN access
API_KEY=

# ---------------------------------------------------------------------------
# Database — Postgres (chạy trong container `db`)
# ---------------------------------------------------------------------------
POSTGRES_DB=money
POSTGRES_USER=money
POSTGRES_PASSWORD=money
DATABASE_URL=postgresql+asyncpg://money:money@db:5432/money

# ---------------------------------------------------------------------------
# LLM providers
# ---------------------------------------------------------------------------
# Provider mặc định cho mọi task local
LLM_DEFAULT_PROVIDER=m1ultra

# --- m1ultra (Ollama native trên máy host M1 Ultra) ---
# ⚠️ Khi chạy trong Docker Compose: đổi 127.0.0.1 → host.docker.internal
#    Khi chạy native dev (không Docker): giữ 127.0.0.1
M1ULTRA_URL=http://127.0.0.1:11434
M1ULTRA_MODEL=jaahas/qwen3.5-uncensored:9b
M1ULTRA_TIMEOUT=120

# --- galaxy_one (remote endpoint) ---
GALAXY_ONE_API_KEY=
GALAXY_ONE_ENDPOINT=https://llms.uat.galaxy.one/api/chat
GALAXY_ONE_MODEL=mistral-cyber-mixlora:0.2311-q4km
GALAXY_ONE_TIMEOUT=120

# Model phụ cho embedding (cùng Ollama instance)
M1ULTRA_EMBED_MODEL=nomic-embed-text

# --- Cloud fallback (OPTIONAL — opt-in) ---
LLM_ALLOW_CLOUD=false
LLM_CLOUD_MONTHLY_BUDGET_USD=5
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_TIMEOUT=60

# ---------------------------------------------------------------------------
# LLM agent (ReAct + tool calling — LangChain + LangGraph)
# ---------------------------------------------------------------------------
LLM_AGENT_ENABLED=true
# Agent model TÁCH KHỎI extract model vì uncensored finetune
# đôi khi phá vỡ tool calling. Dùng instruct model cho agent.
M1ULTRA_AGENT_MODEL=qwen3.5:9b
LLM_AGENT_MAX_STEPS=10
LLM_AGENT_TIMEOUT_SEC=60

# ---------------------------------------------------------------------------
# LLM tools — Gmail readonly access
# (deny-by-default; user cấu hình allowlist trong UI)
# ---------------------------------------------------------------------------
LLM_GMAIL_TOOL_ENABLED=false
LLM_GMAIL_TOOL_MAX_RESULTS=10
LLM_GMAIL_TOOL_BODY_CHARS=2000
LLM_GMAIL_RATE_LIMIT_HOURLY=20

# ---------------------------------------------------------------------------
# Langfuse observability
# Self-host (profile `obs` trong compose) hoặc cloud (opt-in, có warning)
# ---------------------------------------------------------------------------
LANGFUSE_ENABLED=true
# Self-host: http://langfuse:3000 (trong compose) hoặc http://localhost:3001 (host)
# Cloud: https://cloud.langfuse.com (EU) hoặc https://us.cloud.langfuse.com
LANGFUSE_HOST=http://langfuse:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
# Dùng cho self-host init (sinh bằng: openssl rand -base64 24)
LANGFUSE_DB_PASSWORD=
LANGFUSE_NEXTAUTH_SECRET=
LANGFUSE_SALT=

# ---------------------------------------------------------------------------
# Telegram bot (short polling 5s)
# ---------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
# Comma-separated chat_id được phép tương tác bot
TELEGRAM_ALLOWED_CHAT_IDS=
TELEGRAM_POLL_INTERVAL_SEC=5

# ---------------------------------------------------------------------------
# Gmail ingest
# ---------------------------------------------------------------------------
# Email sẽ được đọc (user tự grant qua OAuth — giá trị này chỉ để UI hiển thị
# và verify OAuth consent đúng account).
GMAIL_TARGET_EMAIL=datnlqanalysts@gmail.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/oauth/google/callback
GMAIL_POLL_INTERVAL_SEC=600
# Cron-style: 24h-format hours (local tz, comma-separated) to auto-sync Gmail
# each day. Default "8,20" = sáng 8h + tối 20h. Để trống "" để tắt cron và
# dùng GMAIL_POLL_INTERVAL_SEC ở trên (cũ, polls mỗi 10p — tốn LLM token).
GMAIL_SYNC_HOURS=8,20
# Comma-separated sender filter (glob). Rỗng = nhận tất cả rồi rule engine lọc.
GMAIL_FILTER_SENDERS=
# Mark email as read after successfully ingesting → skipped by next sync.
# Requires scope gmail.modify (granted when reconnecting Gmail).
GMAIL_MARK_READ_AFTER_INGEST=true
# LLM fallback when rule engine misses — m1ultra extracts from body.
GMAIL_LLM_FALLBACK=true
GMAIL_LLM_MAX_BODY_CHARS=20000

# ---------------------------------------------------------------------------
# Backup
# ---------------------------------------------------------------------------
BACKUP_CRON=0 2 * * *
BACKUP_RETENTION_DAYS=30
# Optional: age public key để mã hoá backup
BACKUP_AGE_PUBKEY=
