# =============================================================================
# Secrets & credentials — NEVER commit
# =============================================================================
.env
.env.*
!.env.example
*.key
*.pem
*.p12
*.pfx
*credentials*.json
*client_secret*.json
*oauth*.json
token.json
*.age

# =============================================================================
# User data — contains financial info
# =============================================================================
data/
!data/.gitkeep
backups/
!backups/.gitkeep
logs/
*.db
*.db-journal
*.db-wal
*.db-shm
*.sqlite
*.sqlite3

# =============================================================================
# LLM artifacts
# =============================================================================
# Ollama model weights downloaded locally (if any outside volume). Anchored
# to repo root so it doesn't swallow Python packages named `models/`.
/models/
*.gguf
*.safetensors
llm-cache/

# =============================================================================
# Python
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
ENV/
.eggs/
*.egg-info/
*.egg
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.hypothesis/
.uv/
uv-cache/

